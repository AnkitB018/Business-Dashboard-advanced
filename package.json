{
  "name": "business-dashboard-electron",
  "productName": "Business Dashboard",
  "version": "1.2.0",
  "description": "Employee Management, Wage Calculation, and Business Analytics Dashboard",
  "main": "dist/main.js",
  "author": {
    "name": "Antrocraft and Arolive Build",
    "email": "support@antrocraft.com"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnkitB018/Business-Dashboard-advanced.git"
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:main": "tsc -p tsconfig.main.json",
    "start": "concurrently \"npm run build:dev\" \"npm run build:main\" \"wait-on dist/main.js && electron .\"",
    "dev": "concurrently \"webpack --mode development --watch\" \"wait-on dist/main.js dist/index.html && electron .\"",
    "dist": "npm run build && npm run build:main && electron-builder",
    "dist:win": "npm run build && npm run build:main && electron-builder --win",
    "pack": "npm run build && npm run build:main && electron-builder --dir",
    "release": "npm run build && npm run build:main && electron-builder --publish always",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.antrocraft.businessdashboard",
    "productName": "Business Dashboard",
    "copyright": "Copyright © 2026 Antrocraft and Arolive Build",
    "compression": "maximum",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "LICENSE.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "business-dashboard-setup-${version}.${ext}",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Business Dashboard",
      "license": "LICENSE.md",
      "warningsAsErrors": false,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "displayLanguageSelector": false,
      "installerLanguages": [
        "en_US"
      ],
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "AnkitB018",
      "repo": "Business-Dashboard-advanced",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/xlsx": "^0.0.35",
    "concurrently": "^9.2.1",
    "css-loader": "^7.1.2",
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12",
    "html-webpack-plugin": "^5.6.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.1",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@mui/x-date-pickers": "^8.15.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/recharts": "^1.8.29",
    "dayjs": "^1.11.19",
    "electron-updater": "^6.3.9",
    "mongodb": "^6.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.3.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "kerberos": "^2.1.1",
    "@mongodb-js/zstd": "^1.2.0",
    "@aws-sdk/credential-providers": "^3.705.0",
    "gcp-metadata": "^5.2.0",
    "snappy": "^7.2.2",
    "aws4": "^1.13.2",
    "mongodb-client-encryption": "^6.2.1"
  }
}
